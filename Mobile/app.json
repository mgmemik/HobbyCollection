{
  "expo": {
    "name": "Save All",
    "slug": "save-all",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f06543"
    },
    "ios": {
      "supportsTablet": true,
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSAllowsLocalNetworking": true
        },
        "NSPhotoLibraryUsageDescription": "Bu uygulama fotoğraflarınıza erişmek için izin istiyor.",
        "NSCameraUsageDescription": "Bu uygulama kameranıza erişmek için izin istiyor.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gmemik.saveall",
      "buildNumber": "62"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
