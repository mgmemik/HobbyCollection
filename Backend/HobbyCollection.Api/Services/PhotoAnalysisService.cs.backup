using Google.Cloud.Vision.V1;
using HobbyCollection.Api.Models;
using Microsoft.Extensions.Logging;
using SixLabors.ImageSharp;
using System.Text;

namespace HobbyCollection.Api.Services
{
    public interface IPhotoAnalysisService
    {
        Task<PhotoAnalysisResult> AnalyzePhotosAsync(List<IFormFile> photos);
    }

    public class PhotoAnalysisService : IPhotoAnalysisService
    {
        private readonly ImageAnnotatorClient _visionClient;
        private readonly ILogger<PhotoAnalysisService> _logger;

        public PhotoAnalysisService(ILogger<PhotoAnalysisService> logger)
        {
            _logger = logger;
            // Google Cloud credentials'ı environment variable'dan al
            // GOOGLE_APPLICATION_CREDENTIALS environment variable'ı service account key dosyasının yolunu içermelidir
            _visionClient = ImageAnnotatorClient.Create();
        }

        public async Task<PhotoAnalysisResult> AnalyzePhotosAsync(List<IFormFile> photos)
        {
            try
            {
                _logger.LogInformation("=== NORMAL ANALİZ BAŞLATILIYOR ===");
                _logger.LogInformation($"Fotoğraf sayısı: {photos.Count}");

                if (!photos.Any() || photos.Count > 10)
                {
                    throw new ArgumentException("1 ile 10 arasında fotoğraf gönderilmelidir.");
                }

                var allVisionData = new List<VisionAnalysisData>();

                // Her fotoğraf için Vision API analizi yap
                foreach (var photo in photos)
                {
                    _logger.LogInformation($"Fotoğraf analiz ediliyor: {photo.FileName}, Boyut: {photo.Length} bytes");
                    var visionData = await AnalyzeSinglePhotoAsync(photo);
                    allVisionData.Add(visionData);
                    _logger.LogInformation($"Vision API sonuçları - Labels: {visionData.Labels?.Count ?? 0}, WebEntities: {visionData.WebEntities?.Count ?? 0}, Objects: {visionData.Objects?.Count ?? 0}, Text: {visionData.ExtractedText?.Length ?? 0} karakter");
                }

                _logger.LogInformation("Tüm Vision API analizleri tamamlandı, sonuçlar birleştiriliyor...");

                // Tüm fotoğraflardan gelen verileri birleştir
                var consolidatedResult = ConsolidateAnalysisResults(allVisionData);

                _logger.LogInformation($"=== NORMAL ANALİZ TAMAMLANDI ===");
                _logger.LogInformation($"Sonuç: {consolidatedResult.Title}, Confidence: {consolidatedResult.ConfidenceOverall}");

                return consolidatedResult;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Fotoğraf analizi sırasında hata oluştu");
                throw;
            }
        }

        private async Task<VisionAnalysisData> AnalyzeSinglePhotoAsync(IFormFile photo)
        {
            try
            {
                _logger.LogInformation($"[SINGLE PHOTO] Vision API analizi başlatılıyor: {photo.FileName}");

                // Fotoğrafı byte array'e dönüştür
                byte[] imageBytes;
                using (var memoryStream = new MemoryStream())
                {
                    await photo.CopyToAsync(memoryStream);
                    imageBytes = memoryStream.ToArray();
                }
                _logger.LogInformation($"[SINGLE PHOTO] Görüntü byte array'e dönüştürüldü: {imageBytes.Length} bytes");

                var image = Image.FromBytes(imageBytes);
                _logger.LogInformation($"[SINGLE PHOTO] Vision API Image objesi oluşturuldu");

                // Vision API isteklerini hazırla
                var requests = new List<AnnotateImageRequest>
                {
                    new AnnotateImageRequest
                    {
                        Image = image,
                        Features =
                        {
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.LabelDetection, MaxResults = 50 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.WebDetection, MaxResults = 50 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.ObjectLocalization, MaxResults = 20 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.TextDetection, MaxResults = 20 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.LogoDetection, MaxResults = 10 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.ProductSearch, MaxResults = 10 },
                            new Google.Cloud.Vision.V1.Feature { Type = Google.Cloud.Vision.V1.Feature.Types.Type.SafeSearchDetection, MaxResults = 1 }
                        }
                    }
                };

                _logger.LogInformation($"[SINGLE PHOTO] Vision API istekleri hazırlandı - {requests.Count} istek");

                // Vision API çağrısı
                _logger.LogInformation($"[SINGLE PHOTO] Google Cloud Vision API çağrısı yapılıyor...");
                var response = await _visionClient.BatchAnnotateImagesAsync(requests);

                if (response.Responses.Count == 0)
                {
                    _logger.LogWarning($"[SINGLE PHOTO] Vision API'den yanıt alınamadı");
                    return new VisionAnalysisData();
                }

                var annotation = response.Responses[0];

                // Vision API error kontrolü
                if (annotation.Error != null)
                {
                    _logger.LogWarning($"[SINGLE PHOTO] Vision API hatası: {annotation.Error.Code} - {annotation.Error.Message}");
                    if (annotation.Error.Code == 3) // BAD_IMAGE_DATA
                    {
                        _logger.LogWarning($"[SINGLE PHOTO] Küçük veya bozuk fotoğraf algılandı, boş sonuç döndürülüyor");
                    }
                    return new VisionAnalysisData();
                }

                _logger.LogInformation($"[SINGLE PHOTO] Vision API yanıtı alındı. Response count: {response.Responses.Count}");

                // Annotation sonuçlarını detaylı log'la
                _logger.LogInformation($"[SINGLE PHOTO] Annotation sonuçları - Labels: {annotation.LabelAnnotations?.Count ?? 0}, WebEntities: {annotation.WebDetection?.WebEntities?.Count ?? 0}, Objects: {annotation.LocalizedObjectAnnotations?.Count ?? 0}, Texts: {annotation.TextAnnotations?.Count ?? 0}");

                if (annotation.TextAnnotations?.Count > 0)
                {
                    var firstText = annotation.TextAnnotations[0];
                    _logger.LogInformation($"[SINGLE PHOTO] İlk OCR metni: '{firstText.Description?.Substring(0, Math.Min(100, firstText.Description?.Length ?? 0)) ?? "null"}'");
                }

                // Gelişmiş veri çıkarma
                var visionData = new VisionAnalysisData
                {
                    Labels = annotation.LabelAnnotations.Select(l => new LabelInfo
                    {
                        Description = l.Description,
                        Score = l.Score
                    }).ToList(),

                    WebEntities = annotation.WebDetection?.WebEntities?.Select(w => new WebEntity
                    {
                        EntityId = w.EntityId ?? "",
                        Description = w.Description ?? "",
                        Score = w.Score
                    }).ToList() ?? new List<WebEntity>(),

                    Objects = annotation.LocalizedObjectAnnotations.Select(o => new ObjectInfo
                    {
                        Name = o.Name,
                        Score = o.Score,
                        BoundingBox = new BoundingBox
                        {
                            Vertices = o.BoundingPoly?.NormalizedVertices?.Select(v => new Vertex
                            {
                                X = v.X,
                                Y = v.Y
                            }).ToList() ?? new List<Vertex>()
                        }
                    }).ToList(),

                    ExtractedText = annotation.TextAnnotations?.Count > 0 ?
                        string.Join(" ", annotation.TextAnnotations.Select(t => t.Description)) : ""
                };

                _logger.LogInformation($"[SINGLE PHOTO] Vision API veri çıkarma tamamlandı");
                _logger.LogInformation($"[SINGLE PHOTO] Labels: {visionData.Labels.Count}, WebEntities: {visionData.WebEntities.Count}, Objects: {visionData.Objects.Count}, ExtractedText: {visionData.ExtractedText.Length} karakter");

                return visionData;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"[SINGLE PHOTO] Vision API analizi hatası: {photo.FileName}");
                return new VisionAnalysisData();
            }
        }

        /// <summary>
        /// Tüm analiz sonuçlarını birleştirir
        /// </summary>
        private PhotoAnalysisResult ConsolidateAnalysisResults(List<VisionAnalysisData> visionDataList)
        {
            _logger.LogInformation("[CONSOLIDATE] Analiz sonuçları birleştiriliyor...");

            if (!visionDataList.Any() || visionDataList.All(v => v.Labels.Count == 0))
            {
                _logger.LogWarning("[CONSOLIDATE] Hiç Vision API sonucu bulunamadı");
                return new PhotoAnalysisResult
                {
                    Title = "Bilinmeyen Nesne",
                    ConfidenceOverall = 0.0
                };
            }

            // Tüm label'ları topla ve skorla
            var allLabels = visionDataList
                .SelectMany(v => v.Labels)
                .GroupBy(l => l.Description)
                .Select(g => new
                {
                    Description = g.Key,
                    TotalScore = g.Sum(l => l.Score),
                    Count = g.Count()
                })
                .OrderByDescending(l => l.TotalScore)
                .ToList();

            _logger.LogInformation($"[CONSOLIDATE] Toplam {allLabels.Count} farklı label bulundu");

            // En iyi 5 label'ı log'la
            foreach (var label in allLabels.Take(5))
            {
                _logger.LogInformation($"[CONSOLIDATE] Label: '{label.Description}', Score: {label.TotalScore:F3}, Count: {label.Count}");
            }

            // Title'ı belirle
            var bestLabel = allLabels.FirstOrDefault();
            var title = bestLabel?.Description ?? "Bilinmeyen Nesne";
            _logger.LogInformation($"[CONSOLIDATE] Seçilen başlık: '{title}', Score: {bestLabel?.TotalScore:F3}");

            // Confidence'ı hesapla
            var maxScore = allLabels.Max(l => l.TotalScore);
            var confidence = Math.Min(1.0, maxScore / 2.0); // Normalize et
            _logger.LogInformation($"[CONSOLIDATE] Confidence hesaplandı: {confidence:F3} (maxScore: {maxScore:F3})");

            // OCR metnini birleştir
            var allOcrText = string.Join(" ", visionDataList
                .Where(v => !string.IsNullOrEmpty(v.ExtractedText))
                .Select(v => v.ExtractedText));

            _logger.LogInformation($"[CONSOLIDATE] OCR metni: '{allOcrText.Substring(0, Math.Min(100, allOcrText.Length))}'");

            var result = new PhotoAnalysisResult
            {
                Title = title,
                DescriptionTr = allOcrText,
                ConfidenceOverall = confidence,
                Entities = allLabels.Take(10).Select(l => new DetectedEntity
                {
                    Name = l.Description,
                    Type = "label",
                    Confidence = l.TotalScore / Math.Max(1, l.Count)
                }).ToList()
            };

            _logger.LogInformation($"[CONSOLIDATE] Birleştirme tamamlandı: {result.Title}, Confidence: {result.ConfidenceOverall:F3}");

            return result;
        }
        }
    }
}

                if (!photos.Any() || photos.Count > 10)
                {
                    throw new ArgumentException("1 ile 10 arasında fotoğraf gönderilmelidir.");
                }

                var allVisionData = new List<VisionAnalysisData>();

                // Her fotoğraf için Vision API analizi yap
                foreach (var photo in photos)
                {
                    _logger.LogInformation($"Fotoğraf analiz ediliyor: {photo.FileName}, Boyut: {photo.Length} bytes");
                    var visionData = await AnalyzeSinglePhotoAsync(photo);
                    allVisionData.Add(visionData);
                    _logger.LogInformation($"Vision API sonuçları - Labels: {visionData.Labels?.Count ?? 0}, WebEntities: {visionData.WebEntities?.Count ?? 0}, Objects: {visionData.Objects?.Count ?? 0}, Text: {visionData.ExtractedText?.Length ?? 0} karakter");
                }

                _logger.LogInformation("Tüm Vision API analizleri tamamlandı, sonuçlar birleştiriliyor...");

                // Tüm fotoğraflardan gelen verileri birleştir
                var consolidatedResult = ConsolidateAnalysisResults(allVisionData);

                _logger.LogInformation($"=== NORMAL ANALİZ TAMAMLANDI ===");
                _logger.LogInformation($"Sonuç: {consolidatedResult.Title}, Confidence: {consolidatedResult.ConfidenceOverall}");

                return consolidatedResult;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Fotoğraf analizi sırasında hata oluştu");
                throw;
            }
        }

